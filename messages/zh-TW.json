      "items": {
        "joy": {
          "title": "捕捉最真實的快樂瞬間",
          "desc": "每一趟旅程，都值得被好好收藏。在妳專注挑戰自我與放鬆享受時，我們將以自然不過度干預的方式，為妳們留下生動的活動花絮。不用擔心錯過任何精彩畫面，帶回滿滿的歡樂回憶。"
        },
        "vacation": {
          "title": "放鬆休閒的微度假",
          "desc": "誰說去大自然一定要弄得灰頭土臉？告別傳統戶外的疲憊與克難，從專屬的野營私廚到遊艇旅遊，我們一手包辦所有繁瑣細節，帶您以優雅的姿態，走進台灣最原始的秘境。"
        },
        "guidance": {
          "title": "溫柔引導，無壓力的安全感",
          "desc": "由資深戶外教練領軍，具備完整水域救援與急救證照。以最細膩的耐心帶領妳適應水性。加上高標準的防護裝備與乾淨整潔的器材，讓妳踏的每一步都充滿安全感。"
        }
      }
    },
